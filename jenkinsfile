pipeline {
    agent any

    stages {

    stage('List OF Files'){
           steps{
        bat 'dir'
       }
}
        stage('Run Program') {
            steps {
                sh 'python Avarage.py'
            }
        }

        stage('Archive Report') {
            steps {
                archiveArtifacts artifacts: 'Marks.txt'
            }
        }
    }
}
